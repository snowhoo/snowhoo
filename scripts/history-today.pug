#history-today
  .history-card
    .history-header
      h3
        i.fas.fa-landmark
        | 历史上的今天
      span.history-date#htQueryDate
      .expand-control#htToggle
        span.arrow#htArrow ▼
        span#htExpandText 详情
    #htDetailPanel.detail-panel
      #htEventsContainer.events-list
        .status-message 📭 点击「详情」查看今日历史事件

  script.
    (function(){
      var JSON_FILE = '/js/historyDay.json';
      var currentEvents = null;

      function getToday() {
        var d = new Date();
        var m = String(d.getMonth()+1), day = String(d.getDate());
        return { year: d.getFullYear(), month: m, day: day, display: d.getFullYear()+'年'+m+'月'+day+'日' };
      }

      function fetchFromJSON() {
        return new Promise(function(resolve, reject) {
          var controller = new AbortController();
          var tid = setTimeout(function(){ controller.abort(); }, 5000);
          fetch(JSON_FILE, {signal:controller.signal}).then(function(r){
            clearTimeout(tid);
            if(!r.ok) { reject(new Error('JSON not found')); return; }
            return r.json();
          }).then(function(data){
            clearTimeout(tid);
            if(!data || !Array.isArray(data.events) || data.events.length === 0) {
              reject(new Error('Invalid JSON'));
              return;
            }
            resolve(data.events);
          }).catch(function(e){
            clearTimeout(tid);
            reject(e);
          });
        });
      }

      function render(evs) {
        var c = document.getElementById('htEventsContainer');
        if(!evs || evs.length===0) { c.innerHTML='<div class="status-message">今日暂无历史记载</div>'; return; }
        evs.sort(function(a,b){ return b.year-a.year; });
        var html='';
        for(var i=0;i<evs.length;i++) {
          var link = evs[i].link ? '<a href="'+evs[i].link+'" target="_blank" class="event-title" style="color:#2c445e;text-decoration:none;font-size:0.9rem;line-height:1.45">百科了解事件</a>' : '';
          html+='<div class="event-item"><span class="event-year">'+evs[i].year+'</span><span class="event-title">'+evs[i].text+'</span>'+link+'</div>';
        }
        c.innerHTML=html;
      }

      function setText(s) {
        var t = document.getElementById('htExpandText');
        if(t) t.innerText = s;
      }

      function toggleDetail() {
        var panel = document.getElementById('htDetailPanel');
        var arrow = document.getElementById('htArrow');
        var text = document.getElementById('htExpandText');
        var isOpen = panel.style.display === 'block';
        if(isOpen) {
          panel.style.display = 'none';
          arrow.innerHTML = '▼';
          text.innerText = '详情';
        } else {
          panel.style.display = 'block';
          arrow.innerHTML = '▲';
          text.innerText = '详情';
          if(currentEvents) render(currentEvents);
        }
      }

      var t = getToday();
      document.getElementById('htQueryDate').innerText = t.display;
      document.getElementById('htToggle').addEventListener('click', toggleDetail);

      setText('加载中...');
      fetchFromJSON()
        .then(function(evs){ currentEvents = evs; setText('详情'); })
        .catch(function(){ setText('加载失败'); });
    })();
