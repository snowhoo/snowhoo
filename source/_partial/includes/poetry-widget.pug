#poetry-widget
  style.
    #poetry-widget { max-width: 700px; margin: 0 auto 1.5rem; }
    #poetry-widget .poetry-container { max-width: 700px; margin: 0 auto; font-family: system-ui,-apple-system,'Segoe UI','Noto Sans CJK SC','Microsoft YaHei','WenQuanYi Micro Hei',sans-serif; color: #2c2c2c; line-height: 1.5; }
    #poetry-widget .poem-main { padding: 1rem 0 0.5rem; border-bottom: 1px solid #eaecef; }
    #poetry-widget .verse { font-size: 1.5rem; font-weight: 450; font-family: '楷体','华文楷书','KaiTi','Georgia',serif; color: #1f2d3d; line-height: 1.4; margin-bottom: 0.5rem; }
    #poetry-widget .meta { display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem; font-size: 0.85rem; color: #6c7a8a; margin-top: 0.25rem; }
    #poetry-widget .author { font-weight: 500; color: #4a5b6e; }
    #poetry-widget .dynasty { background: #f0f2f5; padding: 0.1rem 0.5rem; border-radius: 20px; font-size: 0.7rem; }
    #poetry-widget .title { font-size: 0.8rem; color: #8a9bb0; }
    #poetry-widget .expand-control { display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin: 0.75rem 0 0.5rem; padding: 0.25rem 0; cursor: pointer; user-select: none; color: #8f9eb2; font-size: 0.7rem; transition: color 0.2s; border-top: 1px solid #eef2f6; border-bottom: 1px solid #eef2f6; }
    #poetry-widget .expand-control:hover { color: #4a6b8f; }
    #poetry-widget .arrow { font-size: 0.75rem; transition: transform 0.2s ease; display: inline-block; }
    #poetry-widget .detail-panel { display: none; padding: 1rem 0 1.2rem; border-top: 1px solid #eef2f6; margin-top: 0.2rem; font-size: 0.85rem; }
    #poetry-widget .full-poem { background: #fafbfc; padding: 1rem; border-radius: 12px; font-family: '楷体','华文楷书','KaiTi',monospace; white-space: pre-line; line-height: 1.6; color: #2c3e4e; margin-bottom: 1rem; border: 1px solid #edf2f7; }
    #poetry-widget .poet-bio { color: #4a627a; background: #fff; padding: 0.75rem 0; border-left: 3px solid #dce5ef; padding-left: 1rem; font-size: 0.8rem; }
    #poetry-widget .small-note { font-size: 0.65rem; color: #9aabbb; text-align: right; padding-top: 0.5rem; }
    #poetry-widget .refresh-btn { background: none; border: none; font-size: 0.7rem; color: #8f9eb2; cursor: pointer; margin-left: 0.75rem; padding: 0 0.25rem; transition: color 0.2s; }
    #poetry-widget .refresh-btn:hover { color: #56759a; }
    #poetry-widget .loader { display: inline-block; width: 14px; height: 14px; border: 2px solid #e2e6ea; border-radius: 50%; border-top-color: #8ba0b5; animation: poetry-spin 0.6s linear infinite; vertical-align: middle; margin-right: 6px; }
    @keyframes poetry-spin { to { transform: rotate(360deg); } }
    #poetry-widget a, #poetry-widget a:visited { text-decoration: none; }
  .poetry-container
    .poem-main
      .verse#verseLine 采菊东篱下，悠然见南山
      .meta
        span.author#authorName 陶渊明
        span.dynasty#dynastyText 东晋
        span.title#originText 《饮酒·其五》
        button.refresh-btn#refreshBtn(aria-label="换一句") ↻ 换一句
    .expand-control#expandToggle
      span.arrow#arrowIcon ▼
      span 详情
    .detail-panel#detailPanel
      .full-poem#fullPoemContent
      .poet-bio#poetBio
      .small-note ※ 完整诗文及简介依据古典文献整理
  script.
    (function(){
      var detailedPoemsDB = {
        "静夜思":{fullText:"床前明月光，疑是地上霜。\\n举头望明月，低头思故乡。",poetBio:"李白（701－762），字太白，号青莲居士。盛唐浪漫主义诗人，有"诗仙"之称。",dynasty:"唐",author:"李白"},
        "登鹳雀楼":{fullText:"白日依山尽，黄河入海流。\\n欲穷千里目，更上一层楼。",poetBio:"王之涣（688－742），字季凌，盛唐边塞诗人。",dynasty:"唐",author:"王之涣"},
        "春晓":{fullText:"春眠不觉晓，处处闻啼鸟。\\n夜来风雨声，花落知多少。",poetBio:"孟浩然（689－740），襄阳人，唐代山水田园诗派代表。",dynasty:"唐",author:"孟浩然"},
        "江雪":{fullText:"千山鸟飞绝，万径人踪灭。\\n孤舟蓑笠翁，独钓寒江雪。",poetBio:"柳宗元（773－819），字子厚，"唐宋八大家"之一。",dynasty:"唐",author:"柳宗元"},
        "相思":{fullText:"红豆生南国，春来发几枝。\\n愿君多采撷，此物最相思。",poetBio:"王维（701－761），字摩诘，诗画双绝。",dynasty:"唐",author:"王维"},
        "饮酒·其五":{fullText:"结庐在人境，而无车马喧。\\n问君何能尔？心远地自偏。\\n采菊东篱下，悠然见南山。\\n山气日夕佳，飞鸟相与还。\\n此中有真意，欲辨已忘言。",poetBio:"陶渊明（约365－427），字元亮，东晋田园诗人。",dynasty:"东晋",author:"陶渊明"}
      };
      var currentPoemData = {line:"",author:"",dynasty:"",title:"",fullDetail:null};
      function findPoemDetails(title, contentSnippet) {
        if (title && detailedPoemsDB[title]) return detailedPoemsDB[title];
        for (var key in detailedPoemsDB) { var db = detailedPoemsDB[key]; if (db.fullText.indexOf(contentSnippet.substring(0,12)) >= 0) return db; }
        return null;
      }
      async function fetchPoem() {
        var verseEl = document.getElementById("verseLine"), authorEl = document.getElementById("authorName");
        var dynastyEl = document.getElementById("dynastyText"), originEl = document.getElementById("originText");
        verseEl.innerHTML = '<span class="loader"></span> 采撷诗意...';
        authorEl.innerText = ""; dynastyEl.innerText = ""; originEl.innerText = "";
        try {
          var resp = await fetch("https://v2.jinrishici.com/one.json", {headers:{"Cache-Control":"no-cache"}});
          if (!resp.ok) throw new Error();
          var result = await resp.json();
          if (result.status === "success" && result.data) {
            var d = result.data;
            return {line:d.content, author:d.author||"佚名", dynasty:d.dynasty||"古代", title:d.origin||"诗词"};
          } else throw new Error();
        } catch(err) {
          try {
            var backup = await fetch("http://liflag.cn/api/gushici.php?type=json");
            var bd = await backup.json();
            if (bd && bd.content) return {line:bd.content, author:bd.author||"古人", dynasty:bd.source?bd.source.split('·')[0]:"古典", title:bd.source||"诗篇"};
            else throw new Error();
          } catch(e) { return {line:"长风破浪会有时，直挂云帆济沧海。",author:"李白",dynasty:"唐",title:"行路难·其一"}; }
        }
      }
      function updateDetailContent() {
        var fullPoemDiv = document.getElementById("fullPoemContent"), poetBioDiv = document.getElementById("poetBio");
        if (currentPoemData.fullDetail) {
          fullPoemDiv.innerText = currentPoemData.fullDetail.fullText || "「" + currentPoemData.line + "」";
          poetBioDiv.innerText = currentPoemData.fullDetail.poetBio || currentPoemData.author + "，" + currentPoemData.dynasty + "代文学家。";
        } else { fullPoemDiv.innerText = "「" + currentPoemData.line + "」"; poetBioDiv.innerText = currentPoemData.author + "，生平逸事待考。"; }
      }
      async function refreshPoetry() {
        var poem = await fetchPoem();
        document.getElementById("verseLine").innerText = poem.line;
        document.getElementById("authorName").innerText = poem.author;
        document.getElementById("dynastyText").innerText = poem.dynasty;
        document.getElementById("originText").innerText = "《" + poem.title + "》";
        currentPoemData = {line:poem.line, author:poem.author, dynasty:poem.dynasty, title:poem.title, fullDetail:null};
        var matched = findPoemDetails(poem.title, poem.line);
        currentPoemData.fullDetail = matched || {fullText:"「" + poem.line + "」", poetBio:poem.author + "，" + poem.dynasty + "代诗人。"};
        var panel = document.getElementById("detailPanel");
        if (panel.style.display === "block") updateDetailContent();
      }
      function toggleDetail() {
        var panel = document.getElementById("detailPanel"), arrow = document.getElementById("arrowIcon");
        if (panel.style.display !== "block") { updateDetailContent(); panel.style.display = "block"; arrow.innerHTML = "▲"; }
        else { panel.style.display = "none"; arrow.innerHTML = "▼"; }
      }
      document.addEventListener("DOMContentLoaded", function() {
        refreshPoetry();
        document.getElementById("expandToggle").addEventListener("click", toggleDetail);
        document.getElementById("refreshBtn").addEventListener("click", function(e) { e.stopPropagation(); refreshPoetry(); });
      });
    })();
