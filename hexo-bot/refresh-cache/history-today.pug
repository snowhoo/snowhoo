#history-today
  .history-card
    .history-header
      h3 历史上的今天
      span.history-date#htQueryDate
      .expand-control#htToggle
        span.arrow#htArrow ▼
        span#htExpandText 展开详情
    #htDetailPanel.detail-panel
      #htEventsContainer.events-list
        .status-message 📭 点击「展开详情」查看今日历史事件

  script.
    (function(){
      var API = 'https://apis.jxcxin.cn/api/lishi';
      var BASE = 50, INTERVAL = 1500, DUP_LIMIT = 5, MIN = 5, EXTRA = 20;
      var currentEvents = null;
      var CACHE_KEY = 'ht_cache';
      var todayStr = '';

      function getToday() {
        var d = new Date();
        var m = String(d.getMonth()+1), day = String(d.getDate());
        todayStr = d.getFullYear()+'-'+m+'-'+day;
        return { year: d.getFullYear(), month: m, day: day, param: parseInt(m)+'-'+parseInt(day), display: d.getFullYear()+'年'+m+'月'+day+'日' };
      }

      function getCache() {
        try {
          var raw = localStorage.getItem(CACHE_KEY);
          if(!raw) return null;
          var c = JSON.parse(raw);
          if(c.date === todayStr && Array.isArray(c.events) && c.events.length > 0) return c.events;
        } catch(e){}
        return null;
      }

      function setCache(events) {
        try { localStorage.setItem(CACHE_KEY, JSON.stringify({date:todayStr, events:events})); } catch(e){}
      }

      function esc(s) { return s?s.replace(/[&<>]/g,function(m){return m=='&'?'&amp;':m=='<'?'&lt;':m=='>'?'&gt;':m;}):''; }

      function fetchOne(param) {
        return new Promise(function(resolve) {
          var controller = new AbortController();
          var tid = setTimeout(function(){ controller.abort(); }, 6000);
          fetch(API+'?date='+param, {signal:controller.signal}).then(function(r){
            clearTimeout(tid);
            if(!r.ok){ resolve(null); return; }
            return r.text();
          }).then(function(t){
            if(!t){ resolve(null); return; }
            var m = t.match(/^(\d{4})年\d{2}月\d{2}日(.+)/);
            resolve(m?{year:parseInt(m[1]),text:m[2].trim()}:null);
          }).catch(function(){ clearTimeout(tid); resolve(null); });
        });
      }

      function collect(param, onProg) {
        var seen = {}, events = [], empty = 0;
        function tick(i, max, evs) { if(onProg) onProg(i+1, max, evs.length); }
        return new Promise(function(resolve) {
          (function loop(i) {
            if(i >= BASE) {
              if(events.length < MIN) {
                (function extra(j) {
                  if(j >= EXTRA || events.length >= MIN) { resolve(events); return; }
                  fetchOne(param).then(function(ev) {
                    if(ev && !seen[ev.year+'|'+ev.text]) { seen[ev.year+'|'+ev.text]=1; events.push(ev); }
                    else if(ev) empty++;
                    tick(BASE, BASE+EXTRA, events);
                    j++; if(j<EXTRA && events.length<MIN) setTimeout(function(){ extra(j); }, INTERVAL);
                    else resolve(events);
                  });
                })(0);
              } else resolve(events);
              return;
            }
            fetchOne(param).then(function(ev) {
              if(ev) { var key = ev.year+'|'+ev.text; if(!seen[key]) { seen[key]=1; events.push(ev); empty=0; } else empty++; }
              else empty++;
              tick(i, BASE, events);
              if(empty >= DUP_LIMIT) { resolve(events); return; }
              i++; if(i<BASE) setTimeout(function(){ loop(i); }, INTERVAL);
              else loop(i);
            });
          })(0);
        });
      }

      function render(evs) {
        var c = document.getElementById('htEventsContainer');
        if(!evs || evs.length===0) { c.innerHTML='<div class="status-message">📭 今日暂无历史记载</div>'; return; }
        evs.sort(function(a,b){ return b.year-a.year; });
        var html='';
        for(var i=0;i<evs.length;i++) html+='<div class="event-item"><span class="event-year">'+evs[i].year+'</span><span class="event-title">'+esc(evs[i].text)+'</span></div>';
        c.innerHTML=html;
      }

      function setText(s) {
        var t = document.getElementById('htExpandText');
        if(t) t.innerText = s;
      }

      function toggleDetail() {
        var panel = document.getElementById('htDetailPanel');
        var arrow = document.getElementById('htArrow');
        var text = document.getElementById('htExpandText');
        var isOpen = panel.style.display === 'block';
        if(isOpen) {
          panel.style.display = 'none';
          arrow.innerHTML = '▼';
          text.innerText = '展开详情';
        } else {
          panel.style.display = 'block';
          arrow.innerHTML = '▲';
          text.innerText = '收起详情';
          if(currentEvents) render(currentEvents);
        }
      }

      var t = getToday();
      document.getElementById('htQueryDate').innerText = t.display;
      document.getElementById('htToggle').addEventListener('click', toggleDetail);

      var cached = getCache();
      if(cached) {
        currentEvents = cached;
        setText('展开详情 ('+cached.length+'条)');
      } else {
        setText('收集中...');
        collect(t.param, function(cur, tot, n){ setText('收集中 ('+cur+'/'+tot+') '+n+'条'); })
          .then(function(evs){ currentEvents = evs; setCache(evs); setText('展开详情 ('+evs.length+'条)'); })
          .catch(function(){ setText('加载失败'); });
      }
    })();
